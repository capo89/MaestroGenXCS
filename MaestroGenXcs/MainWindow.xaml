<Window x:Class="MaestroGenXcs.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:views="clr-namespace:MaestroGenXcs.Views"
        xmlns:vm="clr-namespace:MaestroGenXcs.ViewModels"
        xmlns:domain="clr-namespace:MaestroGenXcs.Domain"

        Title="MaestroGenXcs – skladanie zostavy"

        Height="640" Width="1000"

        MinHeight="480" MinWidth="800">

    <DockPanel Margin="8">

        <Border DockPanel.Dock="Top" Background="{StaticResource Brush.Panel}"

                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"

                Padding="8" Margin="0,0,0,8">

            <StackPanel>

                <StackPanel Orientation="Horizontal">

                    <Button Style="{StaticResource ToolbarButton}" Content="Import Excel"

                            Command="{Binding ImportExcelCommand}"/>

                    <Button Style="{StaticResource ToolbarButton}" Content="Demo zostava"

                            Command="{Binding LoadDemoCommand}"/>

                    <Button Style="{StaticResource ToolbarButton}" Content="Obeh"

                            Command="{Binding AddOrUpdateObehCommand}"

                            ToolTip="Pridať alebo aktualizovať obeh podľa ABS"/>

                    <Button Style="{StaticResource ToolbarButton}" Content="3D zostava"

                            Click="OnOpen3D_Click"

                            ToolTip="3D pohľad celej zostavy s kolíkmi"/>

                    <Button Style="{StaticResource ToolbarButton}" Content="Export XCS"

                            Command="{Binding ExportXcsCommand}"

                            ToolTip="Export vybraného dielca do jedného .xcs súboru"/>

                    <Button Style="{StaticResource ToolbarButton}" Content="Prepocítaj zostavu"

                            Command="{Binding ApplyAssemblyCommand}"

                            ToolTip="Aplikuje umiestnenia a prepocíta kolíky v zostave"/>

                    <Button Style="{StaticResource ToolbarButton}" Content="Export zostavy"

                            Command="{Binding ExportAssemblyXcsCommand}"

                            ToolTip="Export všetkých dielcov v zostave do priečinka"/>

                </StackPanel>

            </StackPanel>

        </Border>

        <TextBlock DockPanel.Dock="Bottom" Margin="0,8,0,0"

                   Text="{Binding StatusText}" TextWrapping="Wrap" Opacity="0.85"/>

        <Grid>

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="300"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource Brush.Panel}"

                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" Padding="6">

                <DockPanel>

                    <TextBlock DockPanel.Dock="Top" Text="Dielce podľa zostavy" FontWeight="SemiBold" Margin="0,0,0,6"/>

                    <TreeView x:Name="PartsTreeView"
                              ItemsSource="{Binding PartsTree}"
                              SelectedItemChanged="OnPartsTreeSelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type vm:ZostavaTreeNode}"
                                                      ItemsSource="{Binding Parts}">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Margin="0,2,0,2"/>
                            </HierarchicalDataTemplate>
                            <DataTemplate DataType="{x:Type domain:Part}">
                                <TextBlock Text="{Binding Name}" Padding="4,1,2,1"/>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>

                </DockPanel>

            </Border>

            <ScrollViewer Grid.Column="1" Margin="8,0,0,0" VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <Border Background="{StaticResource Brush.Panel}"

                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" Padding="12" Margin="0,0,0,8">

                        <StackPanel>

                            <TextBlock Text="Vybraný dielec" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <TextBlock Opacity="0.85">

                                <Run Text="Názov: "/>

                                <Run Text="{Binding SelectedPart.Name, Mode=OneWay, FallbackValue=–}"/>

                            </TextBlock>

                            <TextBlock Margin="0,4,0,0" Opacity="0.85">

                                <Run Text="Zostava: "/><Run Text="{Binding SelectedZostavaText, Mode=OneWay}"/>

                                <Run Text="   Typ: "/><Run Text="{Binding SelectedKindText, Mode=OneWay}"/>

                            </TextBlock>

                            <TextBlock Margin="0,4,0,0" Opacity="0.85">

                                <Run Text="DX: "/><Run Text="{Binding SelectedDx, Mode=OneWay}"/>

                                <Run Text="   DY: "/><Run Text="{Binding SelectedDy, Mode=OneWay}"/>

                                <Run Text="   DZ: "/><Run Text="{Binding SelectedDz, Mode=OneWay}"/>

                            </TextBlock>

                            <TextBlock Margin="0,4,0,0" Opacity="0.7">

                                <Run Text="Počet operácií: "/>

                                <Run Text="{Binding SelectedPart.Operations.Count, Mode=OneWay, FallbackValue=0}"/>

                            </TextBlock>

                            <TextBlock Margin="0,12,0,4" Opacity="0.85">

                                <Run Text="Referenčný bok: "/>

                                <Run Text="{Binding ReferenceBokText, Mode=OneWay}"/>

                            </TextBlock>

                            <StackPanel Margin="0,8,0,0"
                                        IsEnabled="{Binding HasSelectedZostava}">

                                <TextBlock Text="Režim korpusu" FontWeight="SemiBold" Margin="0,0,0,4"/>

                                <ComboBox ItemsSource="{Binding CorpusModeChoices}"
                                          SelectedValue="{Binding SelectedCorpusMode}"
                                          SelectedValuePath="Mode"
                                          DisplayMemberPath="Label"
                                          Padding="6,4"/>

                            </StackPanel>

                            <StackPanel Visibility="{Binding HasSelectedPlacement, Converter={StaticResource BoolToVis}}">

                                <TextBlock Text="Výška umiestnenia (mm, od spodu)" FontWeight="SemiBold" Margin="0,0,0,4"/>

                                <TextBox Text="{Binding SelectedPlacement.OffsetY, UpdateSourceTrigger=PropertyChanged}"

                                         Padding="6,4" Margin="0,0,0,4"/>

                                <TextBlock Opacity="0.55" FontSize="11" TextWrapping="Wrap"

                                           Text="Zmeň výšku → Prepocítaj zostavu (polica / traverza)."/>

                            </StackPanel>

                        </StackPanel>

                    </Border>

                    <views:PolicaSettingsPanel Visibility="{Binding IsPolicaSelected, Converter={StaticResource BoolToVis}}"/>

                </StackPanel>

            </ScrollViewer>

        </Grid>

    </DockPanel>

</Window>

