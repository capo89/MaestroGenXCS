<Window x:Class="MaestroGenXcs.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:views="clr-namespace:MaestroGenXcs.Views"
        xmlns:vm="clr-namespace:MaestroGenXcs.ViewModels"

        Title="MaestroGenXcs – skladanie zostavy"

        Height="720" Width="1200"

        MinHeight="520" MinWidth="900">

    <DockPanel Margin="8">

        <Border DockPanel.Dock="Top" Background="{StaticResource Brush.Panel}"

                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"

                Padding="8" Margin="0,0,0,8">

            <StackPanel>

                <StackPanel Orientation="Horizontal">

                    <Button Style="{StaticResource ToolbarButton}" Content="Import Excel"

                            Command="{Binding ImportExcelCommand}"/>

                    <Button Style="{StaticResource ToolbarButton}" Content="Demo zostava"

                            Command="{Binding LoadDemoCommand}"/>

                    <Button Style="{StaticResource ToolbarButton}" Content="Obeh"

                            Command="{Binding AddOrUpdateObehCommand}"

                            ToolTip="Pridať alebo aktualizovať obeh podľa ABS"/>

                    <Button Style="{StaticResource ToolbarButton}" Content="Movento"

                            Command="{Binding OpenMoventoCommand}"

                            ToolTip="Nastavenie šuflí Blum Movento pre označenú zostavu"/>

                    <Button Style="{StaticResource ToolbarButton}" Content="Export XCS"

                            Command="{Binding ExportXcsCommand}"

                            ToolTip="Export vybraného dielca do jedného .xcs súboru"/>

                    <Button Style="{StaticResource ToolbarButton}" Content="Prepocítaj zostavu"

                            Command="{Binding ApplyAssemblyCommand}"

                            ToolTip="Aplikuje umiestnenia a prepocíta kolíky v zostave"/>

                    <Button Style="{StaticResource ToolbarButton}" Content="Export zostavy"

                            Command="{Binding ExportAssemblyXcsCommand}"

                            ToolTip="Export všetkých dielcov v zostave do priečinka"/>

                </StackPanel>

            </StackPanel>

        </Border>

        <TextBlock DockPanel.Dock="Bottom" Margin="0,8,0,0"

                   Text="{Binding StatusText}" TextWrapping="Wrap" Opacity="0.85"/>

        <Grid>

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="300"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource Brush.Panel}"

                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" Padding="6">

                <DockPanel>

                    <TextBlock DockPanel.Dock="Top" Text="Dielce podľa zostavy" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock DockPanel.Dock="Top" Opacity="0.65" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                               Text="Označ zostavu alebo dielec v strome – skladanie a 3D idú podľa označenej zostavy."/>

                    <TreeView x:Name="PartsTreeView"
                              ItemsSource="{Binding PartsTree}"
                              SelectedItemChanged="OnPartsTreeSelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="OnTreeItemPreviewMouseRightButtonDown"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type vm:ZostavaTreeNode}"
                                                      ItemsSource="{Binding PartEntries}">
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2"
                                            ToolTip="Kliknutím aktivuješ celú zostavu. Zelená fajka = všetky dielce nastavené a vložené.">
                                    <ContentControl Content="{Binding}"
                                                    ContentTemplate="{StaticResource SetupStatusIconTemplate}"/>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                            <DataTemplate DataType="{x:Type vm:PartTreeEntry}">
                                <StackPanel Orientation="Horizontal"
                                            ToolTip="Zelená fajka = vložený v 3D a má kolíky. Červený kruh = chýba vloženie alebo kolíky.">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu Background="{StaticResource Brush.PanelHeader}"
                                                     BorderBrush="{StaticResource Brush.Border}"
                                                     BorderThickness="1" Padding="2">
                                            <MenuItem Header="Zoznam operácií"
                                                      Foreground="{StaticResource Brush.Foreground}"
                                                      Click="OnShowPartOperations_Click"/>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <ContentControl Content="{Binding}"
                                                    ContentTemplate="{StaticResource SetupStatusIconTemplate}"/>
                                    <TextBlock Text="{Binding Name}" Padding="0,1,2,1" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>

                </DockPanel>

            </Border>

            <views:Assembly3DPanel x:Name="Assembly3DView" Grid.Column="1" Margin="8,0,0,0"/>

        </Grid>

    </DockPanel>

</Window>

