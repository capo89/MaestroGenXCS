<Window x:Class="MaestroGenXcs.Views.AssemblyKolikyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="http://helix-toolkit.org/wpf"
        Title="Kolíky – skladanie zostavy"
        Height="640" Width="920"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel Margin="12">

        <!-- HEADER -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                Padding="10,8" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock x:Name="HeaderLabel"
                           FontSize="14" FontWeight="Bold"
                           Text="Kolíky – skladanie zostavy"/>
                <TextBlock x:Name="SubHeaderLabel" Opacity="0.75"/>
            </StackPanel>
        </Border>

        <!-- FOOTER (akcie) -->
        <Border DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource ToolbarButton}" Content="Zrušiť" Click="OnCancel_Click" Margin="0,0,8,0" Padding="14,6" MinWidth="80"/>
                <Button Style="{StaticResource ToolbarButton}" Content="Uložiť" Click="OnOk_Click" IsDefault="True" Padding="14,6" MinWidth="100"/>
            </StackPanel>
        </Border>

        <!-- Aktívne šablóny – zhrnutie -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                
                Padding="10" Margin="0,10,0,0">
            <StackPanel>
                <TextBlock Text="Použijú sa tieto šablóny (Nastavenie operácií):"
                           FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock x:Name="TemplatePreviewLabel"
                           FontFamily="Consolas"
                           Opacity="0.85"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Plocha a Pattern picker -->
                <Border Background="{StaticResource Brush.Panel}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        
                        Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left"
                                       Text="Plocha (workplane):"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBlock x:Name="FaceLabel"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                                       FontFamily="Consolas"
                                       FontWeight="Bold"/>
                        </DockPanel>

                        <!-- Pattern radio (zobrazí sa len pre Top – 2 možnosti).
                             Pre hrany je len jeden pattern (Hrana) – auto-vybraný. -->
                        <StackPanel x:Name="PatternPickerForTop"
                                    Orientation="Horizontal" Margin="0,8,0,0"
                                    Visibility="Collapsed">
                            <TextBlock Text="Pattern: "
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <RadioButton x:Name="RadioPlochaX"
                                         Content="Plocha po X" GroupName="Pattern"
                                         IsChecked="True"
                                         Margin="0,0,12,0" VerticalAlignment="Center"
                                         Checked="OnPatternRadio_Checked"/>
                            <RadioButton x:Name="RadioPlochaY"
                                         Content="Plocha po Y" GroupName="Pattern"
                                         VerticalAlignment="Center"
                                         Checked="OnPatternRadio_Checked"/>
                        </StackPanel>

                        <TextBlock x:Name="PatternFixedLabel"
                                   Margin="0,8,0,0"
                                   FontFamily="Consolas"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Traverza: kolíky v hrane + poloha na bokoch + smer patternu -->
                <Border x:Name="TraverzaPanel"
                        Background="{StaticResource Brush.Panel}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        
                        Padding="10" Margin="0,0,0,10"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Traverza – kolíky (vždy tieto plochy)" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TraverzaPloskyLabel"
                                   FontFamily="Consolas"
                                   Opacity="0.9"
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Predvolby: Nastavenie operácií → Traverza kolíky." Opacity="0.75" Margin="0,0,0,8" TextWrapping="Wrap"/>

                        <TextBlock Text="Smer patternu na hrane traverzy:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <RadioButton x:Name="RadioTraverzaPredZad"
                                     GroupName="TraverzaPattern"
                                     Content="Zpredu → vzadu (po osi Y hrany)"
                                     IsChecked="True"
                                     Margin="0,0,0,4"/>
                        <RadioButton x:Name="RadioTraverzaLavPrav"
                                     GroupName="TraverzaPattern"
                                     Content="Zľava → vpravo (po osi X hrany)"
                                     Margin="0,0,0,10"/>

                        <TextBlock Text="Poloha prvého kolíka na bokoch (Top):" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Prvý kolík X (bok)" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TraverzaBokXBox" Padding="6,4" Margin="0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="mm" VerticalAlignment="Center" Foreground="#FF8BB6FF"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Prvý kolík Y (bok)" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TraverzaBokYBox" Padding="6,4" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="mm" VerticalAlignment="Center" Foreground="#FF8BB6FF"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="OppositeBokPanel"
                        Background="{StaticResource Brush.Panel}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        
                        Padding="10" Margin="0,0,0,10"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Druhý bok" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <RadioButton x:Name="RadioPreniestNaBok"
                                     GroupName="OppositeBok"
                                     Content="Preniesť na druhý bok (Bok P / Bok L)"
                                     IsChecked="True"
                                     Margin="0,0,0,4"/>
                        <RadioButton x:Name="RadioIbaPartner"
                                     GroupName="OppositeBok"
                                     Content="Iba Dno / Vrch (neprenášať na druhý bok)"/>
                    </StackPanel>
                </Border>

                <!-- Pattern hodnoty (4 polia) -->
                <Border Background="{StaticResource Brush.Panel}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        
                        Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Pattern parametre (predvyplnené zo šablóny):"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" x:Name="LblNumberOfRows"    Text="numberOfRows"     VerticalAlignment="Center" FontFamily="Consolas" Margin="0,3"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="NumberOfRowsBox"     Padding="6,4" Margin="0,3" FontFamily="Consolas"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" x:Name="LblNumberOfColumns" Text="numberOfColumns"  VerticalAlignment="Center" FontFamily="Consolas" Margin="0,3"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="NumberOfColumnsBox"  Padding="6,4" Margin="0,3" FontFamily="Consolas"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" x:Name="LblRowsDistance"    Text="rowsDistance"     VerticalAlignment="Center" FontFamily="Consolas" Margin="0,3"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="RowsDistanceBox"     Padding="6,4" Margin="0,3" FontFamily="Consolas"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="UnitRowsDistance"   Text="mm" VerticalAlignment="Center" Foreground="#FF8BB6FF"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" x:Name="LblColumnDistance"  Text="columnDistance"   VerticalAlignment="Center" FontFamily="Consolas" Margin="0,3"/>
                            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="ColumnDistanceBox"   Padding="6,4" Margin="0,3" FontFamily="Consolas"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="UnitColumnDistance" Text="mm" VerticalAlignment="Center" Foreground="#FF8BB6FF"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Poloha tejto inštancie (zadáva užívateľ) -->
                <Border Background="{StaticResource Brush.Panel}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        
                        Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Poloha tejto inštancie:" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" x:Name="LblName"   Text="Meno operácie" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="NameBox" Padding="6,4" Margin="0,3"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" x:Name="LblRefpos" Text="Refpos (0..3)" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="RefposBox" Text="0" Padding="6,4" Margin="0,3"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" x:Name="LblXStart" Text="Prvý kolík X" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="XStartBox" Text="37" Padding="6,4" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="UnitXStart" Text="mm" VerticalAlignment="Center" Foreground="#FF8BB6FF"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" x:Name="LblYStart" Text="Prvý kolík Y" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="YStartBox" Text="37" Padding="6,4" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="UnitYStart" Text="mm" VerticalAlignment="Center" Foreground="#FF8BB6FF"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

            <Border Grid.Column="1" Margin="10,0,0,0"
                    Background="{StaticResource Brush.Panel}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"  Padding="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Náhľad dielca (pohľad Top)"
                               FontWeight="SemiBold" Margin="4,4,4,6"/>
                    <h:HelixViewport3D x:Name="PreviewViewport"
                                       ZoomExtentsWhenLoaded="True"
                                       ShowCoordinateSystem="False"
                                       ShowViewCube="False"
                                       Background="{StaticResource Brush.Panel}">
                        <h:DefaultLights/>
                    </h:HelixViewport3D>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>



