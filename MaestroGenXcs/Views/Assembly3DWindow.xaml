<Window x:Class="MaestroGenXcs.Views.Assembly3DWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="http://helix-toolkit.org/wpf"
        Title="3D skladanie zostavy – MaestroGenXcs"
        Height="720" Width="1100"
        MinHeight="520" MinWidth="900"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <h:HelixViewport3D x:Name="Viewport"
                               ZoomExtentsWhenLoaded="True"
                               ShowFrameRate="False"
                               ShowCoordinateSystem="True"
                               ShowViewCube="True"
                               Focusable="True"
                               Background="#FF111114">
                <h:HelixViewport3D.RotateGesture>
                    <MouseGesture MouseAction="RightClick" Modifiers="Shift"/>
                </h:HelixViewport3D.RotateGesture>
                <h:HelixViewport3D.PanGesture>
                    <MouseGesture MouseAction="RightClick"/>
                </h:HelixViewport3D.PanGesture>
                <h:DefaultLights/>
            </h:HelixViewport3D>

            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Opacity="0.92"
                        IsHitTestVisible="False">
                <TextBlock x:Name="TitleLabel" FontSize="16" FontWeight="Bold" Foreground="White"
                           Text="Zostava"/>
                <TextBlock x:Name="DetailLabel" Foreground="LightGray" TextWrapping="Wrap"/>
                <TextBlock x:Name="SelectedPartLabel" Foreground="#FF4EC9B0" Margin="0,6,0,0" TextWrapping="Wrap"/>
                <TextBlock Foreground="#FFAAAAAA" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"
                           Text="Otáčanie: Shift + pravé. Posun pohľadu: pravé. Zoom: koliesko. Diel: Shift + ľavé (po Vložiť)."/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                <Button Style="{StaticResource ToolbarButton}" Content="TOP" Click="OnViewTop_Click" IsDefault="True"/>
            </StackPanel>
        </Grid>

        <Border Grid.Column="1" Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1,0,0,0" Padding="10">
            <DockPanel DataContext="{Binding Panel}">
                <TextBlock DockPanel.Dock="Top" Text="Pravítko (mm)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock DockPanel.Dock="Top" Opacity="0.65" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"
                           Text="Pomocné čiary – X (od pravej hrany boku) = pravý okraj dielca, Y (od prednej) = predný okraj. Pri ťahaní sa nemenia."/>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="X" VerticalAlignment="Center" Foreground="#FFFFA500"/>
                    <TextBox Grid.Column="1" Margin="4,0,8,0" Padding="4,3"
                             Text="{Binding GuideX, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                    <TextBlock Grid.Column="2" Text="Y" VerticalAlignment="Center" Foreground="#FFFFA500"/>
                    <TextBox Grid.Column="3" Margin="4,0,0,0" Padding="4,3"
                             Text="{Binding GuideY, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                </Grid>

                <TextBlock DockPanel.Dock="Top" Text="Dielce na vloženie" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock DockPanel.Dock="Top" Opacity="0.65" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"
                           Text="Bok L je vždy v scéne. ⚙ = editor dielca (operácie, kolíky). Vložiť = umiestniť; Upraviť = vrátiť sa k vloženému."/>

                <ListBox ItemsSource="{Binding InsertItems}" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                    Padding="8" Margin="0,0,0,6" CornerRadius="3">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Style="{StaticResource ToolbarButton}"
                                                Content="{Binding InsertButtonText}"
                                                Command="{Binding InsertCommand}"
                                                MinWidth="72" Margin="8,0,0,0"/>
                                        <Button Style="{StaticResource ToolbarButton}"
                                                Content="⚙"
                                                ToolTip="Editor dielca – operácie a kolíky"
                                                Command="{Binding OpenPinSettingsCommand}"
                                                Width="32" Margin="6,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Dimensions}" Opacity="0.75" FontSize="11"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>
