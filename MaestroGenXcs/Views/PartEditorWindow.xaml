<Window x:Class="MaestroGenXcs.Views.PartEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="http://helix-toolkit.org/wpf"
        Title="Editor dielca"
        Height="640" Width="960"
        MinHeight="480" MinWidth="760"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <h:HelixViewport3D x:Name="Viewport"
                               ZoomExtentsWhenLoaded="True"
                               ShowFrameRate="False"
                               ShowCoordinateSystem="True"
                               ShowViewCube="True"
                               Background="#FF111114"
                               MouseLeftButtonDown="OnViewport_MouseLeftButtonDown">
                <h:DefaultLights/>
            </h:HelixViewport3D>

            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Opacity="0.92">
                <TextBlock x:Name="TitleLabel" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="HintLabel" Foreground="#FFAAAAAA" FontSize="11" Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Text="Klikni na plochu (Top alebo hrany) – otvorí sa dialóg kolíkov. Po dokončení zavri editor a v zostave stlač Vložiť."/>
                <TextBlock x:Name="SelectedFaceLabel" Foreground="#FF4EC9B0" Margin="0,8,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                <Button Style="{StaticResource ToolbarButton}" Content="3D" Click="OnViewIso_Click"/>
                <Button Style="{StaticResource ToolbarButton}" Content="TOP" Click="OnViewTop_Click"/>
                <Button Style="{StaticResource ToolbarButton}" Content="L" Click="OnViewLeft_Click"/>
                <Button Style="{StaticResource ToolbarButton}" Content="P" Click="OnViewRight_Click"/>
                <Button Style="{StaticResource ToolbarButton}" Content="F" Click="OnViewFront_Click"/>
                <Button Style="{StaticResource ToolbarButton}" Content="B" Click="OnViewBack_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Column="1" Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1,0,0,0" Padding="10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Style="{StaticResource ToolbarButton}" Content="Zapnúť všetky"
                                Click="OnEnableAll_Click" Margin="0,0,6,0"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="Vypnúť všetky"
                                Click="OnDisableAll_Click" Margin="0,0,6,0"/>
                        <Button Style="{StaticResource ToolbarButton}" Content="Odstrániť"
                                Click="OnRemoveSelected_Click"/>
                    </StackPanel>
                    <Button x:Name="SpecialKolikyButton" Style="{StaticResource ToolbarButton}"
                            Content="Nastaviť kolíky" Click="OnSpecialKoliky_Click"
                            Visibility="Collapsed" Margin="0,0,0,8"/>
                    <Button Style="{StaticResource ToolbarButton}" Content="Hotovo"
                            IsDefault="True" Click="OnDone_Click" HorizontalAlignment="Stretch"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Top" Text="Operácie" FontWeight="Bold" Margin="0,0,0,6"/>
                <Border DockPanel.Dock="Top" Background="{StaticResource Brush.PanelHeader}" Padding="8,6" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock x:Name="HeaderPartLabel" FontWeight="Bold"/>
                        <TextBlock x:Name="HeaderCountLabel" Opacity="0.75" FontSize="11"/>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Top" x:Name="NoteRow" Padding="8,6" Margin="0,0,0,8"
                        Background="#FF1F2A38" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1"
                        Cursor="Hand" MouseLeftButtonUp="OnNoteRow_Click">
                    <Grid>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" Text="✎" Foreground="#FF8BB6FF"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Poznámka exportu" FontSize="11"/>
                                <TextBlock x:Name="NotePreviewLabel" Opacity="0.75" FontStyle="Italic" FontSize="10"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DockPanel>
                        <Popup x:Name="NotePopup" PlacementTarget="{Binding ElementName=NoteRow}" Placement="Bottom"
                               AllowsTransparency="True" PopupAnimation="Fade" StaysOpen="False">
                            <Border Background="#FF1F2A38" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                    CornerRadius="6" Padding="10" MinWidth="320" MaxWidth="400">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="Poznámka pre export" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                        <Button DockPanel.Dock="Left" Content="↺ Predvolené"
                                                Click="OnNotePopupReset_Click" Padding="6,3" FontSize="11"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Zrušiť" Click="OnNotePopupCancel_Click" Margin="0,0,4,0" Padding="8,3" MinWidth="60"/>
                                            <Button Content="Uložiť" Click="OnNotePopupSave_Click" IsDefault="True" Padding="8,3" MinWidth="60"/>
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBox x:Name="NotePopupTextBox" MinHeight="80" TextWrapping="Wrap" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                                             KeyDown="OnNotePopupTextBox_KeyDown"/>
                                </DockPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>

                <TextBlock DockPanel.Dock="Top" Text="Operácie dielca" FontWeight="SemiBold" Margin="0,0,0,6"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                <ListBox x:Name="OperationsList" BorderThickness="0" Background="Transparent"
                         SelectionChanged="OnOperationsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1"
                                    Padding="8,6" Margin="0,0,0,2">
                                <DockPanel>
                                    <CheckBox DockPanel.Dock="Right" VerticalAlignment="Center" Margin="6,0,0,0"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                              Checked="OnOperationEnabledChanged"
                                              Unchecked="OnOperationEnabledChanged"/>
                                    <TextBlock DockPanel.Dock="Right" Text="✎" Foreground="#FF8BB6FF"
                                               VerticalAlignment="Center" Margin="4,0,4,0" Opacity="0.85"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Opacity="0.7" FontSize="11">
                                            <Run Text="{Binding TypeLabel, Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding Face, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                    <Border x:Name="DrillEditorBorder" Grid.Row="1" Margin="0,8,0,0" Padding="8"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="3"
                            Visibility="Collapsed">
                        <Grid x:Name="DrillEditorRoot" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Detail vŕtania" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="1" Text="Meno" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="EditNameBox" Margin="6,2,0,2" TextChanged="OnDrillEditChanged"/>
                            <TextBlock Grid.Row="2" Text="Refpos" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="EditRefPosBox" Margin="6,2,0,2" TextChanged="OnDrillEditChanged"/>
                            <TextBlock Grid.Row="3" Text="Počet X/Y" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="6,2,0,2">
                                <TextBox x:Name="EditCountXBox" Width="54" Margin="0,0,6,0" TextChanged="OnDrillEditChanged"/>
                                <TextBox x:Name="EditCountYBox" Width="54" TextChanged="OnDrillEditChanged"/>
                            </StackPanel>
                            <TextBlock Grid.Row="4" Text="Rozteč X/Y" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="6,2,0,2">
                                <TextBox x:Name="EditPitchXBox" Width="54" Margin="0,0,6,0" TextChanged="OnDrillEditChanged"/>
                                <TextBox x:Name="EditPitchYBox" Width="54" TextChanged="OnDrillEditChanged"/>
                            </StackPanel>
                            <TextBlock Grid.Row="5" Text="Start X/Y" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="6,2,0,2">
                                <TextBox x:Name="EditStartXBox" Width="54" Margin="0,0,6,0" TextChanged="OnDrillEditChanged"/>
                                <TextBox x:Name="EditStartYBox" Width="54" TextChanged="OnDrillEditChanged"/>
                            </StackPanel>
                            <TextBlock Grid.Row="6" Text="Hĺbka" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="6" Grid.Column="1" x:Name="EditDepthBox" Margin="6,2,0,2" TextChanged="OnDrillEditChanged"/>
                            <TextBlock Grid.Row="7" Text="Priemer" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="7" Grid.Column="1" x:Name="EditDiameterBox" Margin="6,2,0,2" TextChanged="OnDrillEditChanged"/>
                            <TextBlock Grid.Row="8" Text="Nástroj" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="8" Grid.Column="1" x:Name="EditToolBox" Margin="6,2,0,2" TextChanged="OnDrillEditChanged"/>
                        </Grid>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Window>
