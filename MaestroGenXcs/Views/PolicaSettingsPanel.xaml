<UserControl x:Class="MaestroGenXcs.Views.PolicaSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border Background="{StaticResource Brush.PanelHeader}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="0,0,0,1"
            Padding="8,8,8,6"
            DataContext="{Binding SelectedPart}">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Polica" FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBlock DockPanel.Dock="Top" Opacity="0.65" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"
                       Text="Kolíky a podpery sa po zmene parametrov doplnia automaticky (nie v zozname Operácie)."/>

            <ScrollViewer DockPanel.Dock="Top" MaxHeight="300" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Typ police" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton Content="Pevná (kolíky)"
                                     GroupName="PolicaTyp"
                                     IsChecked="{Binding PolicaJePevna, Mode=TwoWay}"
                                     Margin="0,0,16,0"/>
                        <RadioButton Content="Polohovateľná (podpery)"
                                     GroupName="PolicaTyp"
                                     IsChecked="{Binding PolicaJePolohovatelna, Mode=TwoWay}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding PolicaJePevna, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Utopenie police (mm)" Opacity="0.8" FontSize="11" Margin="0,0,0,2"
                                   ToolTip="Odsadenie od prednej hrany pri vŕtaní do bokov."/>
                        <TextBox Text="{Binding PolicaFrontOffsetMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                 Padding="6,4" Margin="0,0,0,8"/>
                    </StackPanel>

                    <CheckBox Content="Iba jeden rad podpier"
                              IsChecked="{Binding PolicaIbaJedenRad, Mode=TwoWay}"
                              Margin="0,0,0,8">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PolicaJePevna}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <TextBlock Text="Série (1 séria = 1 ks)" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding PolicaSerie}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                        Background="#FF1A2430" Padding="8" Margin="0,0,0,6" CornerRadius="3">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Nazov}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Od spodu (mm)" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding OdSpoduMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                                     Margin="6,0,0,0" Padding="4,3"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Od prednej hrany (mm)" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding OdPrednejHranyMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                                     Margin="6,0,0,0" Padding="4,3"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Rozteč kolíkov (mm)"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedPart.PolicaJePevna, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                                <Setter Property="Text" Value="Rozteč podpier (mm)"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding RoztecMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                                     Margin="6,0,0,0" Padding="4,3"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Počet kolíkov"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedPart.PolicaJePevna, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                                <Setter Property="Text" Value="Počet polôh"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBox Grid.Column="1" Text="{Binding PocetKolikov, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="6,0,0,0" Padding="4,3">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedPart.PolicaJePevna, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <TextBox Grid.Column="1" Text="{Binding PocetPoloh, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="6,0,0,0" Padding="4,3">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedPart.PolicaJePevna, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="Vymazať"
                                                    Style="{StaticResource PanelSecondaryButton}"
                                                    Command="{Binding DataContext.ClearPolicaSeriaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,6,0"/>
                                            <Button Content="Kopíruj predch."
                                                    Style="{StaticResource PanelSecondaryButton}"
                                                    Command="{Binding DataContext.CopyPolicaSeriaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
