<UserControl x:Class="MaestroGenXcs.Views.SufelBokPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="http://helix-toolkit.org/wpf">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <h:HelixViewport3D x:Name="Viewport"
                               ZoomExtentsWhenLoaded="True"
                               ShowFrameRate="False"
                               ShowCoordinateSystem="True"
                               ShowViewCube="True"
                               Focusable="True"
                               Background="#FF111114">
                <h:HelixViewport3D.RotateGesture>
                    <MouseGesture MouseAction="RightClick" Modifiers="Shift"/>
                </h:HelixViewport3D.RotateGesture>
                <h:HelixViewport3D.PanGesture>
                    <MouseGesture MouseAction="RightClick"/>
                </h:HelixViewport3D.PanGesture>
                <h:DefaultLights/>
            </h:HelixViewport3D>

            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Opacity="0.92"
                        IsHitTestVisible="False">
                <TextBlock x:Name="TitleLabel" FontSize="16" FontWeight="Bold" Foreground="White"
                           Text="Šufľový bok"/>
                <TextBlock x:Name="DetailLabel" Foreground="LightGray" TextWrapping="Wrap"/>
                <TextBlock Foreground="#FFAAAAAA" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"
                           Text="Otáčanie: Shift + pravé. Posun: pravé. Zoom: koliesko."/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                <Button Style="{StaticResource ToolbarButton}" Content="TOP" Click="OnViewTop_Click"/>
                <Button Style="{StaticResource ToolbarButton}" Content="3D" Click="OnViewIso_Click" Margin="6,0,0,0"/>
            </StackPanel>
        </Grid>

        <Border Grid.Column="1" Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1,0,0,0" Padding="10">
            <DockPanel DataContext="{Binding Panel}">
                <Button DockPanel.Dock="Top" Style="{StaticResource ToolbarButton}"
                        Content="← Späť na zostavu"
                        Command="{Binding AssemblyVm.BackToCabinetAssemblyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        HorizontalAlignment="Stretch" Margin="0,0,0,10"/>

                <TextBlock DockPanel.Dock="Top" Text="Makro SufelBok2_novy" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock DockPanel.Dock="Top" Foreground="#FFAAAAAA" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"
                           Text="Parametre pre celú šufľu. Rozmery dx1/dy1/dz1 z importu."/>

                <Border DockPanel.Dock="Top" Background="{StaticResource Brush.PanelHeader}" Padding="8,6" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding SkupinaNazov}" Opacity="0.8" FontSize="11"/>
                        <TextBlock Text="{Binding RozmeryText}" Opacity="0.75" FontSize="11"/>
                        <TextBlock Text="{Binding PocetKsText}" Opacity="0.75" FontSize="11"/>
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding Macro}">
                        <TextBlock Text="Kolíky do boku" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="72"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="PolohaDieryX" VerticalAlignment="Center"
                                       ToolTip="Vypočítané z hrúbky čelo/zad ÷ 2"/>
                            <TextBlock Grid.Column="1" Margin="6,2,0,2" Padding="4,2"
                                       VerticalAlignment="Center" Foreground="#FFCCCCCC"
                                       Text="{Binding PolohaDieryXmm, StringFormat=F1}"/>
                            <TextBlock Grid.Row="1" Text="PolohaDieryY" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="6,2,0,2" Padding="4,2"
                                     Text="{Binding PolohaDieryYmm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                            <TextBlock Grid.Row="2" Text="PocetDier" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="6,2,0,2" Padding="4,2"
                                     Text="{Binding PocetDier, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="3" Text="RoztecDier" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="6,2,0,2" Padding="4,2"
                                     Text="{Binding RoztecDierMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                            <TextBlock Grid.Row="4" Text="HlbkaDier" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Margin="6,2,0,2" Padding="4,2"
                                     Text="{Binding HlbkaDierMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                        </Grid>
                        <TextBlock Text="{Binding CeloZadHrubkaText, RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.Panel}"
                                   Foreground="#FFAAAAAA" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="Makro SufelCeloZad2 (čelo + zad)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Foreground="#FFAAAAAA" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,6"
                                   Text="Odvodené z boku: PocetDier, RoztecDier rovnaké; PolohaDiery = PolohaDieryY − 2 mm."/>
                        <Grid Margin="0,0,0,8" DataContext="{Binding CeloZadMacro, RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.Panel}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="72"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="PocetDier" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Margin="6,2,0,2" Padding="4,2"
                                       VerticalAlignment="Center" Foreground="#FFCCCCCC"
                                       Text="{Binding PocetDier}"/>
                            <TextBlock Grid.Row="1" Text="RoztecDier" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="6,2,0,2" Padding="4,2"
                                       VerticalAlignment="Center" Foreground="#FFCCCCCC"
                                       Text="{Binding RoztecDierMm, StringFormat=F1}"/>
                            <TextBlock Grid.Row="2" Text="PolohaDiery" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="6,2,0,2" Padding="4,2"
                                       VerticalAlignment="Center" Foreground="#FFCCCCCC"
                                       Text="{Binding PolohaDieryMm, StringFormat=F1}"/>
                        </Grid>

                        <TextBlock Text="Drážka pre dno" FontWeight="SemiBold" Margin="0,4,0,6"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="72"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="HlbkaDrazky" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Margin="6,2,0,2" Padding="4,2"
                                     Text="{Binding HlbkaDrazkyMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                            <TextBlock Grid.Row="1" Text="Pridavok" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="6,2,0,2" Padding="4,2"
                                     Text="{Binding PridavokMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                            <TextBlock Grid.Row="2" Text="Paska" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="6,2,0,2" Padding="4,2"
                                     Text="{Binding PaskaMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                            <TextBlock Grid.Row="3" Text="hlbkaZafrezovania" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="6,2,0,2" Padding="4,2"
                                     Text="{Binding HlbkaZafrezovaniaMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                            <TextBlock Grid.Row="4" Text="frezpod" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Margin="6,2,0,2" Padding="4,2"
                                     Text="{Binding FrezPodMm, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
