<Window x:Class="MaestroGenXcs.Views.AssemblyEdgeKolikyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Koliky"
        Height="300" Width="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanMinimize">
    <DockPanel Margin="10">
        <Border DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource ToolbarButton}" Content="Zrusit" IsCancel="True" Padding="14,6" MinWidth="80" Margin="0,0,8,0"/>
                <Button Style="{StaticResource ToolbarButton}" Content="Ulozit" IsDefault="True" Click="OnOk_Click" Padding="14,6" MinWidth="90"/>
            </StackPanel>
        </Border>

        <Border Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                Padding="10">
            <StackPanel>
                <TextBlock x:Name="TitleLabel" FontSize="14" FontWeight="Bold" Text="Koliky"/>
                <TextBlock x:Name="FaceLabel" Opacity="0.75" Margin="0,4,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Od prednej hrany" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="OdPrednejHranyBox" Padding="6,4" Margin="0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="mm" VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Pocet kolikov" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="PocetBox" Padding="6,4" Margin="0,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Roztec kolikov" VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="RoztecBox" Padding="6,4" Margin="0,4"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="mm" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>
    </DockPanel>
</Window>
